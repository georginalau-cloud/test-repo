# -*- coding: utf-8 -*-
"""
[00] bin/bazi - 八字精批分析主入口（顶层调用入口）
调用链：
  [00] bin/bazi
    → [06] src/bazi_chart.py
        → [01] src/cities_longitude.py
        → [04] src/yuanju.py → [02] src/jieqi.py, [03] lib/ganzhi_calculator.py
        → [05] src/dayun.py → [02] src/jieqi.py
    → [07] src/bazi_chart_year.py
    → [08] src/bazi_chart_month.py
    → [09] src/bazi_chart_day.py
    → [11] lib/ten_gods_analyzer.py
    → [13] lib/format_analyzer.py → [12] lib/yongshen_analyzer.py
    → [14] lib/character_profiler.py
    → [15] lib/six_relations_analyzer.py
    → [16] lib/wealth_career_analyzer.py
    → [17] lib/health_predictor.py
    → [18] lib/luck_cycle_analyzer.py → [10] lib/zhi_relations.py
    → [19] lib/advice_generator.py
    → [20] lib/wuyu_analyzer.py → [10] lib/zhi_relations.py
    → [21] lib/ancient_books_fetcher.py
    → [22] lib/daily_fortune.py

调用方式（OpenClaw exec 工具）：
  # 完整精批
  python3 bin/bazi --year 1990 --month 1 --day 8 --hour 15 --minute 45 \
                   --gender female --city 西安 --mode full

  # 月运分析（指定流年+流月）
  python3 bin/bazi --year 1990 --month 1 --day 8 --hour 15 --minute 45 \
                   --gender female --city 西安 --mode monthly \
                   --liuyear 2026 --liuyue-month 4

  # 日运分析（指定流年+流月+流日）
  python3 bin/bazi --year 1990 --month 1 --day 8 --hour 15 --minute 45 \
                   --gender female --city 西安 --mode daily \
                   --liuyear 2026 --liuyue-month 4 --liuri-date 2026-04-15

参数：
  --year          公历出生年
  --month         公历出生月（1-12）
  --day           公历出生日（1-31）
  --hour          出生小时（24小时制，北京时间）
  --minute        出生分钟（0-59）
  --gender        male / female
  --city          出生城市（用于真太阳时校准）
  --mode          full（完整精批）/ quick（仅排盘）/ monthly（月运）/ daily（日运）
  --level         同 --mode，兼容旧调用方式
  --liuyear       流年（公历年份），monthly/daily 模式使用，默认今年
  --liuyue-month  流月月序（1=寅月…12=丑月），monthly/daily 模式使用
  --liuyue-gz     流月干支（如 丙辰），优先级高于 --liuyue-month
  --liuri-date    流日日期 YYYY-MM-DD，daily 模式使用，默认今天

输出：JSON，写入 stdout
"""

