#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
紫微斗数完整分析入口
调用：python3 bin/ziwei --year 1990 --month 1 --day 8 --hour 14 --minute 54 --gender female --city 上海 --mode full

输出结构化数据 + prompt_for_llm，供 LLM 做命盘解读
"""

import os
import sys
import json
import argparse

_SKILL_DIR = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
sys.path.insert(0, os.path.join(_SKILL_DIR, 'vendor'))

from iztro_py import astro

# ─── 星辰中英对照 ───────────────────────────────────────────────
